{
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint --no-error-on-unmatched-pattern --config .eslintrc.json --ignore-path .eslintignore ../*",
    "lint:prettier": "prettier --check --config .prettierrc.json --ignore-path .prettierignore ..",
    "lint:types": "tsc --noEmit --project tsconfig.json || echo 'No TypeScript files found - skipping type check'",
    "lint:all": "npm run lint:eslint && npm run lint:prettier && npm run lint:types",
    "lint:watch": "nodemon -e ts --exec \"clear; npm run lint\"",
    "format": "prettier --write --config .prettierrc.json --ignore-path .prettierignore ..",
    "analyze:complexity": "eslint --no-error-on-unmatched-pattern --config .eslintrc.json --ignore-path .eslintignore ../* --format json > ../.eslint-report.json || true",
    "analyze:security": "npm audit --json > ../.npm-audit.json || true",
    "analyze": "npm run analyze:complexity && npm run analyze:security && echo 'Analysis complete. Check .eslint-report.json and .npm-audit.json'"
  },
  "homepage": "https://github.com/JimmyPaolini",
  "name": "jimmypaolini",
  "author": "Jimmy Paolini",
  "description": "Jimmy Paolini",
  "repository": "https://github.com/JimmyPaolini",
  "version": "0.0.0",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.0.0",
    "eslint-plugin-react": "^7.33.2",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
